{
  "name": "lattice-editor",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "Live editor + validator + topology visualiser for Lattice documents (editor.lattice-spec.org).",
  "scripts": {
    "predev": "node scripts/copy-artifacts.mjs",
    "dev": "vite",
    "prebuild": "node scripts/copy-artifacts.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run test:conformance && npm run test:unit && npm run test:resolve && npm run test:merge && npm run test:transform && npm run test:graph",
    "test:conformance": "node scripts/conformance.mjs",
    "test:unit": "node --test scripts/conformance.test.mjs",
    "build:ref": "tsc src/resolve-engine.ts src/merge-engine.ts src/transform-engine.ts src/graph/eval.ts --outDir scripts/.gen --module esnext --target es2020 --moduleResolution bundler --skipLibCheck",
    "pretest:resolve": "npm run build:ref",
    "test:resolve": "node --test scripts/resolve-conformance.test.mjs",
    "resolve:record": "npm run build:ref && node scripts/resolve-record.mjs",
    "pretest:merge": "npm run build:ref",
    "test:merge": "node --test scripts/merge-engine.test.mjs scripts/merge-conformance.test.mjs",
    "merge:record": "npm run build:ref && node scripts/merge-record.mjs",
    "pretest:transform": "npm run build:ref",
    "test:transform": "node --test scripts/transform-engine.test.mjs scripts/transform-conformance.test.mjs",
    "transform:record": "npm run build:ref && node scripts/transform-record.mjs",
    "pretest:graph": "npm run build:ref",
    "test:graph": "node --test scripts/eval.test.mjs"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@monaco-editor/react": "^4.6.0",
    "@xyflow/react": "^12.11.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "cytoscape": "^3.30.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.21.8",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.5"
  }
}
